# Copy this to .env.local and fill in your values
# Do not commit .env.local to source control

# 1. Google OAuth Credentials (Get from Google Cloud Console)
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"

# 2. NextAuth Configuration
# Run `openssl rand -base64 32` or just put a long random string here for development
NEXTAUTH_SECRET="your_super_secret_string_here_12345"
# Change this to your Vercel URL when deployed (e.g. https://your-app.vercel.app)
NEXTAUTH_URL="http://localhost:3000"

# 3. Security Allowlist
# Comma separated list of emails allowed to log in
ALLOWED_EMAILS="yourname@gmail.com,teacher@school.edu"

# 4. Google Gemini API Key
GEMINI_API_KEY="AIzaSy..."
